# Alpaca — used ONLY for the news endpoint (Benzinga symbol-tagged feed).
# Not a broker commitment; broker is TBD at slice 8.
# Generate at alpaca.markets > Paper Trading > API Keys (free, paper-only).
# Required when fetching news. NOT required for OHLCV (yfinance needs no account).
ALPACA_KEY=
ALPACA_SECRET=

# Optional: override the default DuckDB path (defaults to data/hyx.duckdb).
# HYX_DB_PATH=

# Optional: override the default reports directory (defaults to reports/).
# HYX_REPORTS_DIR=
