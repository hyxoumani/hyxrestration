# Alpaca paper trading credentials.
# Generate at alpaca.markets > Paper Trading > API Keys.
# Slice 1 uses these for both OHLCV and news endpoints.
ALPACA_KEY=
ALPACA_SECRET=

# Optional: override the default DuckDB path (defaults to data/hyx.duckdb).
# HYX_DB_PATH=

# Optional: override the default reports directory (defaults to reports/).
# HYX_REPORTS_DIR=
